# ============================================================
# KGKB — Docker Compose Environment Variables
# Copy to .env and customize as needed
# ============================================================

# Port mapping
KGKB_BACKEND_PORT=8000
KGKB_FRONTEND_PORT=3000

# Backend log level (debug, info, warning, error)
KGKB_LOG_LEVEL=info

# Embedding configuration
# Provider: ollama, openai, custom
KGKB_EMBEDDING_PROVIDER=ollama
KGKB_EMBEDDING_MODEL=qwen3-embedding:0.6b
# For Docker: use host.docker.internal to reach Ollama on the host
KGKB_EMBEDDING_ENDPOINT=http://host.docker.internal:11434
