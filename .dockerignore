# ============================================================
# .dockerignore — Exclude from Docker build context
# ============================================================

# Git
.git
.gitignore

# Night factory (development-only)
.night-factory/

# Python caches
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
venv/
.venv/
env/
ENV/

# Node modules (frontend installs fresh in container)
node_modules/
frontend/node_modules/

# Frontend build output (rebuilt in container)
frontend/dist/
frontend/build/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Environment files (secrets — don't bake into image)
.env
.env.local
.env.*.local

# Database files (mounted as volume, not baked)
*.db
*.sqlite
*.sqlite3
.kgkb/

# Vector indexes (mounted as volume)
*.faiss
*.index
chroma_db/

# OS junk
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Temporary
tmp/
temp/
*.tmp

# Docker files themselves
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation (not needed at runtime)
docs/
*.md
!README.md
LICENSE
CONTRIBUTING.md
